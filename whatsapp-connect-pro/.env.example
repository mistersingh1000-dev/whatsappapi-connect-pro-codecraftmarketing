# ---- Auth / Free trial ----
# Generate: openssl rand -base64 32
AUTH_SECRET=replace_with_a_long_random_secret
TRIAL_DAYS=7

# ---- Supabase (accounts + login + repeat-trial prevention) ----
# Project Settings -> Data API / API keys
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # server-only, keep secret

# ---- Shared trial WhatsApp number (optional) ----
WHATSAPP_TRIAL_PHONE_NUMBER_ID=
WHATSAPP_TRIAL_TOKEN=
WHATSAPP_API_VERSION=v21.0

# ---- Meta / WhatsApp Embedded Signup ----
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
NEXT_PUBLIC_META_CONFIG_ID=your_embedded_signup_config_id
META_APP_SECRET=your_meta_app_secret

# ---- Razorpay (payments) ----
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---- Admin Panel ----
# Email of the administrator who can access /admin
ADMIN_EMAIL=mistersingh1000@gmail.com
